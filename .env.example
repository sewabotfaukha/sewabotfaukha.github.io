# =============================================================================
# Faukha — Contoh Environment Variables
# =============================================================================
# Saat ini landing page masih 100% statis (data dummy di /data), jadi belum ada
# env var yang WAJIB diisi supaya `npm run dev` jalan. File ini disiapkan untuk
# tahap pengembangan berikutnya (dashboard bot, integrasi API, payment gateway).
#
# Cara pakai:
# 1. Copy file ini jadi ".env.local"      -> cp .env.example .env.local
# 2. Isi value sesuai kredensial masing-masing environment.
# 3. JANGAN commit ".env.local" ke git (sudah di-ignore lewat .gitignore).
# =============================================================================

# --- WhatsApp Business API (rencana: aktivasi otomatis bot setelah pembayaran) ---
WHATSAPP_API_KEY=
WHATSAPP_API_BASE_URL=

# --- Telegram Bot API (rencana: provisioning bot Telegram otomatis) ---
TELEGRAM_BOT_TOKEN=

# --- Payment Gateway (rencana: Midtrans/Xendit untuk checkout paket) ---
PAYMENT_GATEWAY_KEY=
PAYMENT_GATEWAY_SECRET=
PAYMENT_GATEWAY_MODE=sandbox

# --- Analytics (opsional) ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- URL situs (dipakai untuk resolve og:image & metadataBase di app/layout.tsx) ---
NEXT_PUBLIC_SITE_URL=https://faukha.example.com
